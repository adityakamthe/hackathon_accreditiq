# ============================================
# AccreditIQ Chatbot — Environment Variables
# ============================================
# Copy this file as .env and fill in your keys

# Mistral API Key (required for AI responses)
MISTRAL_API_KEY=your-mistral-api-key-here

# Supabase Project URL & Anon Key (required for database & file storage)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key-here

# Server Port (optional, defaults to 3000)
PORT=3000
